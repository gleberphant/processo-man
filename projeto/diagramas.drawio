        <mxCell id="iRDCXI-dqFB4oNn8-roO-108" value="&lt;h3 data-path-to-node=&quot;13&quot;&gt;&lt;b data-path-to-node=&quot;13&quot; data-index-in-node=&quot;0&quot;&gt;Visão Geral do Fluxo de Dados&lt;/b&gt;&lt;/h3&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;15&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;15,0,0&quot;&gt;O &lt;b data-path-to-node=&quot;15,0,0&quot; data-index-in-node=&quot;2&quot;&gt;Roteador&lt;/b&gt; recebe a requisição.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;15,1,0&quot;&gt;O &lt;b data-path-to-node=&quot;15,1,0&quot; data-index-in-node=&quot;2&quot;&gt;Manipulador&lt;/b&gt; extrai os dados (do formulário HTML ou da URL).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;15,2,0&quot;&gt;O &lt;b data-path-to-node=&quot;15,2,0&quot; data-index-in-node=&quot;2&quot;&gt;Serviço&lt;/b&gt; valida as regras de negócio.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;15,3,0&quot;&gt;O &lt;b data-path-to-node=&quot;15,3,0&quot; data-index-in-node=&quot;2&quot;&gt;Repositório&lt;/b&gt; (dentro do Serviço) salva no banco.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;15,4,0&quot;&gt;O &lt;b data-path-to-node=&quot;15,4,0&quot; data-index-in-node=&quot;2&quot;&gt;Manipulador&lt;/b&gt; decide: ou envia um &lt;code data-path-to-node=&quot;15,4,0&quot; data-index-in-node=&quot;34&quot;&gt;ExecuteTemplate&lt;/code&gt; (HTML) ou um &lt;code data-path-to-node=&quot;15,4,0&quot; data-index-in-node=&quot;63&quot;&gt;json.Encode&lt;/code&gt; (API).&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" style="text;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" vertex="1" parent="1">
          <mxGeometry x="10" y="-190" width="1020" height="170" as="geometry" />
        </mxCell>
